# ──────────────────────────────────────────────────────────────
# Open Format 3D Viewer — Frontend
# Production .gitignore for GitHub + Vercel
# ──────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────
dist/
dist-ssr/
build/
.vercel/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing artifacts ────────────────────────────────────────
coverage/
test-results/
playwright-report/
blob-report/

# ── Local config ─────────────────────────────────────────────
*.local

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ── Archives / backups ───────────────────────────────────────
*.zip
*.rar
*.7z
*.tar.gz

# ── Ignore accidental nested repos / duplicates ──────────────
Open-Format-3D-Viewer/
